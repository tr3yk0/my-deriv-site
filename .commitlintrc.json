{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "header-max-length": [2, "always", 100],
    "type-enum": [
      2,
      "always",
      [
        "build",
        "bugfix",
        "ci",
        "chore",
        "docs",
        "feat",
        "fix",
        "hotfix",
        "perf",
        "refactor",
        "revert",
        "style",
        "test",
        "redeploy",
        "translations"
      ]
    ],
    "subject-case": [0, "always"],
    "scope-case": [2, "always", "kebab-case"],
    "subject-empty": [2, "never"],
    "type-empty": [2, "never"]
  },
  "parserPreset": {
    "parserOpts": {
      "noteKeywords": ["BREAKING CHANGE", "BREAKING CHANGES"]
    }
  }
}
