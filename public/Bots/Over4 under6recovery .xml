<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="phase_tracker">ActivePhase</variable>
    <variable id="base_stake">BaseStake</variable>
    <variable id="current_stake">CurrentStake</variable>
    <variable id="consecutive_losses">ConsecutiveLosses</variable>
    <variable id="acc_loss">AccumulatedLoss</variable>
    <variable id="max_multiplier">MaxRecoveryMultiplier</variable>
  </variables>
  <block type="trade_definition" id="quant_master_init" deletable="false" x="0" y="110">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="market_def" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_100</field>
        <next>
          <block type="trade_definition_tradetype" id="trade_type_def" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="contract_type_def" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="candle_def" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="restart_def" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="error_def" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="init_phase">
        <field name="VAR" id="phase_tracker">ActivePhase</field>
        <value name="VALUE">
          <block type="text" id="text_primary">
            <field name="TEXT">PRIMARY_OVER4</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="init_stake">
            <field name="VAR" id="base_stake">BaseStake</field>
            <value name="VALUE">
              <block type="math_number" id="val_base_stake">
                <field name="NUM">0.5</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="init_curr_stake">
                <field name="VAR" id="current_stake">CurrentStake</field>
                <value name="VALUE">
                  <block type="variables_get" id="get_base_stake">
                    <field name="VAR" id="base_stake">BaseStake</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="init_max_mult">
                    <field name="VAR" id="max_multiplier">MaxRecoveryMultiplier</field>
                    <value name="VALUE">
                      <block type="math_number" id="val_max_mult">
                        <field name="NUM">8</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="init_acc_loss">
                        <field name="VAR" id="acc_loss">AccumulatedLoss</field>
                        <value name="VALUE">
                          <block type="math_number" id="val_acc_loss">
                            <field name="NUM">0</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="trade_options">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <block type="math_number" id="val_duration">
            <field name="NUM">1</field>
          </block>
        </value>
        <value name="AMOUNT">
          <block type="variables_get" id="get_amount">
            <field name="VAR" id="current_stake">CurrentStake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="W#KESevp@?DsrK#Zv6Ym" inline="true">
            <field name="NUM">1</field>
          </shadow>
          <block type="logic_ternary" id="dynamic_prediction">
            <value name="IF">
              <block type="logic_compare" id="check_phase_pred">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="get_phase_pred">
                    <field name="VAR" id="phase_tracker">ActivePhase</field>
                  </block>
                </value>
                <value name="B">
                  <block type="text" id="val_primary_text">
                    <field name="TEXT">PRIMARY_OVER4</field>
                  </block>
                </value>
              </block>
            </value>
            <value name="THEN">
              <block type="math_number" id="pred_over_4">
                <field name="NUM">4</field>
              </block>
            </value>
            <value name="ELSE">
              <block type="math_number" id="pred_under_6">
                <field name="NUM">6</field>
              </block>
            </value>
          </block>
        </value>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="evaluation_engine" x="1444" y="110">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="outcome_router">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="check_win">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="reset_loss_counter">
            <field name="VAR" id="consecutive_losses">ConsecutiveLosses</field>
            <value name="VALUE">
              <block type="math_number" id="val_zero_losses">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="reset_acc_loss">
                <field name="VAR" id="acc_loss">AccumulatedLoss</field>
                <value name="VALUE">
                  <block type="math_number" id="val_zero_acc">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="revert_phase">
                    <field name="VAR" id="phase_tracker">ActivePhase</field>
                    <value name="VALUE">
                      <block type="text" id="txt_revert_primary">
                        <field name="TEXT">PRIMARY_OVER4</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="revert_stake">
                        <field name="VAR" id="current_stake">CurrentStake</field>
                        <value name="VALUE">
                          <block type="variables_get" id="get_base_revert">
                            <field name="VAR" id="base_stake">BaseStake</field>
                          </block>
                        </value>
                        <next>
                          <block type="notify" id="notify_recovery_success">
                            <field name="NOTIFICATION_TYPE">success</field>
                            <field name="NOTIFICATION_SOUND">silent</field>
                            <value name="MESSAGE">
                              <block type="text" id="msg_rec_success">
                                <field name="TEXT">Sequence Cleared. Resuming Primary Phase.</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="math_change" id="increment_acc_loss">
            <field name="VAR" id="acc_loss">AccumulatedLoss</field>
            <value name="DELTA">
              <block type="math_single" id="abs_loss_val">
                <field name="OP">ABS</field>
                <value name="NUM">
                  <block type="read_details" id="read_loss_amount">
                    <field name="DETAIL_INDEX">4</field>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="variables_set" id="switch_to_recovery">
                <field name="VAR" id="phase_tracker">ActivePhase</field>
                <value name="VALUE">
                  <block type="text" id="txt_switch_rec">
                    <field name="TEXT">RECOVERY_UNDER6</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="calc_recovery_stake">
                    <field name="VAR" id="current_stake">CurrentStake</field>
                    <value name="VALUE">
                      <block type="math_arithmetic" id="math_rec_stake">
                        <field name="OP">ADD</field>
                        <value name="A">
                          <block type="math_arithmetic" id="math_loss_mult">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <block type="variables_get" id="get_acc_for_math">
                                <field name="VAR" id="acc_loss">AccumulatedLoss</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="val_payout_mult">
                                <field name="NUM">1.6</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="get_base_for_math">
                            <field name="VAR" id="base_stake">BaseStake</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="check_ceiling">
                        <value name="IF0">
                          <block type="logic_compare" id="ceiling_compare">
                            <field name="OP">GT</field>
                            <value name="A">
                              <block type="variables_get" id="get_curr_for_ceiling">
                                <field name="VAR" id="current_stake">CurrentStake</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_arithmetic" id="math_ceiling">
                                <field name="OP">MULTIPLY</field>
                                <value name="A">
                                  <block type="variables_get" id="get_base_ceiling">
                                    <field name="VAR" id="base_stake">BaseStake</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="get_mult_ceiling">
                                    <field name="VAR" id="max_multiplier">MaxRecoveryMultiplier</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="notify" id="notify_circuit_breaker">
                            <field name="NOTIFICATION_TYPE">error</field>
                            <field name="NOTIFICATION_SOUND">silent</field>
                            <value name="MESSAGE">
                              <block type="text" id="msg_circuit_breaker">
                                <field name="TEXT">CRITICAL: Max Drawdown Ceiling Breached. Halting.</field>
                              </block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="trade_again" id="loop_trade"></block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="execution_engine" deletable="false" x="0" y="984">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="phase_router">
        <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1"></mutation>
        <value name="IF0">
          <block type="logic_compare" id="route_primary">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="get_route_primary">
                <field name="VAR" id="phase_tracker">ActivePhase</field>
              </block>
            </value>
            <value name="B">
              <block type="text" id="route_primary_text">
                <field name="TEXT">PRIMARY_OVER4</field>
              </block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="notify" id="notify_primary_edge">
            <field name="NOTIFICATION_TYPE">info</field>
            <field name="NOTIFICATION_SOUND">silent</field>
            <value name="MESSAGE">
              <block type="text" id="msg_primary_edge">
                <field name="TEXT">[Primary] Entropy Confirmed. Executing Over 4.</field>
              </block>
            </value>
            <next>
              <block type="purchase" id="purchase_over">
                <field name="PURCHASE_LIST">DIGITOVER</field>
              </block>
            </next>
          </block>
        </statement>
        <value name="IF1">
          <block type="logic_compare" id="route_recovery">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="get_route_recovery">
                <field name="VAR" id="phase_tracker">ActivePhase</field>
              </block>
            </value>
            <value name="B">
              <block type="text" id="route_recovery_text">
                <field name="TEXT">RECOVERY_UNDER6</field>
              </block>
            </value>
          </block>
        </value>
        <statement name="DO1">
          <block type="notify" id="notify_recovery_edge">
            <field name="NOTIFICATION_TYPE">warn</field>
            <field name="NOTIFICATION_SOUND">silent</field>
            <value name="MESSAGE">
              <block type="text" id="msg_recovery_edge">
                <field name="TEXT">[Recovery] Under 6 Coverage Activated.</field>
              </block>
            </value>
            <next>
              <block type="purchase" id="purchase_under">
                <field name="PURCHASE_LIST">DIGITUNDER</field>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>